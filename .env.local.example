# Supabase (create project at https://supabase.com — choose EU region)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic (for AI-conducted qualitative interviews)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Resend (for email invitations — https://resend.com)
RESEND_API_KEY=your_resend_api_key

# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret

# App URL (used in emails and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
